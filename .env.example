# Copy to .env and fill in. All values are optional — with no keys set, the app
# uses the built-in offline "mock" provider so you can try it immediately.

# --- Provider selection ---
# anthropic | openai | mock   (auto-detected from keys if left unset)
# LLM_PROVIDER=anthropic

# Override the model (defaults: claude-opus-4-8 for anthropic, gpt-4o-mini for openai)
# LLM_MODEL=claude-opus-4-8

# --- API keys ---
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# --- Optional tuning ---
# VLE_MAX_INPUT_CHARS=120000   # max characters of the document sent to the model
# VLE_MAX_UPLOAD_BYTES=26214400 # 25 MB upload cap
# VLE_MAX_IMAGES=40            # max images extracted per document
# VLE_DATA_DIR=./data          # where uploads + extracted images are written
